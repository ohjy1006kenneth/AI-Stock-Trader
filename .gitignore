# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv / local tooling
.venv/
.openclaw/
.env

# OpenClaw local workspace files
/AGENTS.md
/SOUL.md
/USER.md
/TOOLS.md
/HEARTBEAT.md
/IDENTITY.md
/memory/

# Temp scratch files
/.tmp_*.md
*.tmp

# Local credentials
/config/alpaca.env

# Runtime / generated state
/logs/*
!/logs/README.md

/data/cache/**
!/data/cache/.gitkeep
/data/raw/**
!/data/raw/.gitkeep
/data/processed/**
!/data/processed/.gitkeep
/data/runtime/**
!/data/runtime/.gitkeep
!/data/runtime/market/.gitkeep
!/data/runtime/strategy/.gitkeep
!/data/runtime/execution/.gitkeep
!/data/runtime/diagnostics/.gitkeep
!/data/runtime/alerts/.gitkeep

# Local portfolio state
/ledger/*.json
!/ledger/.gitkeep

# Generated artifacts
/artifacts/bundles/**
!/artifacts/bundles/.gitkeep
/artifacts/deployments/**
!/artifacts/deployments/.gitkeep

# Generated reports
/reports/backtests/**/*.json
/reports/backtests/**/*.csv
/reports/backtests/**/*.md
!/reports/backtests/.gitkeep
/reports/pipeline/**/*.json
/reports/pipeline/**/*.log
/reports/pipeline/**/*.md
!/reports/pipeline/.gitkeep
/reports/diagnostics/**/*.json
/reports/diagnostics/**/*.log
/reports/diagnostics/**/*.md
!/reports/diagnostics/.gitkeep
/reports/daily/**/*.md
!/reports/daily/.gitkeep
/reports/integration/**
!/reports/integration/.gitkeep

# Ignore old local cleanup areas if recreated
/archive/
/trash/
