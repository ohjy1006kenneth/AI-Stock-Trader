# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.conda/

# Environment and secrets — never commit these
*.env
*.env.*
!config/examples/*.env.example
.envrc
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx

# Runtime config with real values — examples are committed, actuals are not
config/runtime.json
!config/examples/runtime.example.json
alpaca.env
!config/examples/alpaca.env.example

# Data — large files stay local or in R2, not in git
data/raw/
data/processed/
data/runtime/
*.parquet
*.csv
*.feather
*.arrow

# Model artifacts — stored in R2/artifacts, not git
artifacts/bundles/
artifacts/manifests/
artifacts/backtests/
*.pkl
*.joblib
*.ubj
*.model
*.bin
*.pt
*.pth
*.onnx

# Logs
logs/
*.log
*.log.*

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/
junit.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

