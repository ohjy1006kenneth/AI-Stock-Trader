.conda/

# Environment and secrets — never commit these
*.env
*.env.*
.envrc
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx

# Runtime config with real values — never commit actual secrets/config state
config/runtime.json
alpaca.env

# Data — large files stay local or in R2, not in git
data/raw/
data/processed/
data/runtime/
data/cache/
*.parquet
*.csv
*.feather
*.arrow

# Exception: sample fixture files for unit tests must be committed
!data/sample/
!data/sample/**

# Model artifacts — stored in R2/artifacts, not git
artifacts/bundles/
artifacts/manifests/
artifacts/backtests/
*.pkl
*.joblib
*.ubj
*.model
*.bin
*.pt
*.pth
*.onnx

# Logs
logs/
*.log
*.log.*

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/
junit.xml

