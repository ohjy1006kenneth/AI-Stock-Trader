{
  "price_snapshot": {
    "required_fields": ["generated_at", "source", "items"],
    "item_required_fields": ["ticker", "timestamp", "open", "high", "low", "close", "adj_close", "volume"],
    "fallback_source_allowed": true
  },
  "fundamental_snapshot": {
    "required_fields": ["generated_at", "source", "items"],
    "item_required_fields": ["ticker", "timestamp"],
    "fallback_source_allowed": true
  },
  "strategist_decisions": {
    "required_fields": ["generated_at", "decision_schema_version", "decisions"]
  },
  "execution_log": {
    "required_fields": ["generated_at", "execution_schema_version", "items"]
  }
}
