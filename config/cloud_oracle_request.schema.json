{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cloud Oracle Request",
  "type": "object",
  "required": ["portfolio", "universe"],
  "additionalProperties": false,
  "properties": {
    "portfolio": {
      "type": "object",
      "required": ["cash", "positions"],
      "additionalProperties": false,
      "properties": {
        "cash": { "type": "number", "minimum": 0 },
        "positions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ticker", "qty", "entry_price"],
            "additionalProperties": false,
            "properties": {
              "ticker": { "type": "string", "minLength": 1 },
              "qty": { "type": "integer", "minimum": 0 },
              "entry_price": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "universe": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ticker", "history", "news"],
        "additionalProperties": false,
        "properties": {
          "ticker": { "type": "string", "minLength": 1 },
          "history": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["date", "open", "high", "low", "close", "volume"],
              "additionalProperties": false,
              "properties": {
                "date": { "type": "string" },
                "open": { "type": "number" },
                "high": { "type": "number" },
                "low": { "type": "number" },
                "close": { "type": "number" },
                "volume": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "news": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date", "headline", "summary"],
              "additionalProperties": false,
              "properties": {
                "date": { "type": "string" },
                "headline": { "type": "string" },
                "summary": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
