{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cloud Oracle Response",
  "type": "object",
  "required": ["model_version", "generated_at", "request_id", "predictions"],
  "additionalProperties": false,
  "properties": {
    "model_version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "predictions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ticker", "target_weight", "confidence", "signal_type"],
        "additionalProperties": false,
        "properties": {
          "ticker": { "type": "string", "minLength": 1 },
          "target_weight": { "type": "number", "minimum": 0, "maximum": 0.2 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "signal_type": { "type": "string", "enum": ["long"] }
        }
      }
    }
  }
}
